    "@types/react-dom": "^18",
    "@types/supertest": "^7.2.0",
    "allure-commandline": "^2.40.0",
    "allure-jest": "^3.7.2",
    "allure-playwright": "^3.7.2",
    "autoprefixer": "^10.0.1",
    "jest": "^30.4.1",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "snyk": "^1.1304.2",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.9",
    "typescript": "^5"
