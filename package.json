{
  "name": "spiritual-programme",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prebuild": "node scripts/build-content.js",
    "start": "next start",
    "content": "node scripts/build-content.js",
    "validate-content": "node scripts/validate-content.js",
    "generate-tree": "node scripts/generate-tree.js > project-structure.txt",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:perf": "k6 run __tests__/performance/load.js",
    "test:perf:ci": "k6 run --env BASE_URL=$BASE_URL __tests__/performance/load.js",
    "security:snyk": "bash __tests__/security/snyk.sh",
    "security:audit": "npm audit"
  },
  "dependencies": {
